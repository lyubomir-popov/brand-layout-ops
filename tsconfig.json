{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "exactOptionalPropertyTypes": true
  },
  "include": [
    "packages/**/*.ts",
    "examples/**/*.ts",
    "apps/**/*.ts"
  ]
}